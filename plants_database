-- Create the plants table
CREATE TABLE plants (
    id INT PRIMARY KEY,
    name VARCHAR(25),
    species VARCHAR(50),
    type VARCHAR(15),
    min_dli INT,
    max_dli INT
);

-- Insert rows of data into the plants table
